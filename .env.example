# SENTINEL-AI Configuration Template
# Copy to .env and fill in your values

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TRIAGE_MODEL=llama3.1
OLLAMA_GUARDRAIL_MODEL=mistral
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ChromaDB Configuration
CHROMADB_PATH=./knowledge_base/chroma_store
CHROMADB_COLLECTION_NAME=mitre_attack

# MITRE ATT&CK Configuration
MITRE_STIX_URL=https://raw.githubusercontent.com/mitre/cti/master/enterprise-attack/enterprise-attack.json

# Dataset Configuration
CICIDS_PATH=./data/raw/
PROCESSED_DATA_PATH=./data/processed/
ADVERSARIAL_DATA_PATH=./data/adversarial/

# Agent Configuration
MAX_ITERATIONS=3
CONFIDENCE_THRESHOLD=0.7
INJECTION_CONFIDENCE_THRESHOLD=0.8

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/sentinel-ai.log

# Streamlit Dashboard
DASHBOARD_PORT=8501
DASHBOARD_HOST=0.0.0.0

# Evaluation Settings
EVAL_RESULTS_PATH=./evaluation/results/
EVAL_SAMPLE_SIZE=200